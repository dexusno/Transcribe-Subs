# Copy this file to .env and add your API key(s).
#
# .env is gitignored and will not be uploaded to GitHub.
# You only need the key for the profile you use.
# Default profile is DeepSeek Reasoner — the rest are optional alternatives.

# DeepSeek (default) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-key-here

# ── Optional alternatives ────────────────────────────────────────────────────
# Uncomment and fill in only if you want to use a different LLM provider.
# Switch profiles with: .\transcribe_subs.ps1 "D:\Movies" -Profile openai

# OpenAI    — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-key-here

# Groq      — https://console.groq.com/keys
# GROQ_API_KEY=your-key-here

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-key-here

# Local (Ollama/LM Studio) — no key needed, just run: ollama serve
